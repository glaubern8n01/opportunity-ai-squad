# =============================================================================
# Opportunity AI Squad — variáveis de ambiente
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA faça commit do arquivo .env — apenas deste .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=opportunity-ai-squad
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL / Supabase)
# Use a connection string do pooler (porta 6543) em produção.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/opportunity_squad
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Provedor de IA (Anthropic)
# -----------------------------------------------------------------------------
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5
ANTHROPIC_MODEL_DEEP=claude-opus-4-8

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Plugins habilitados (separados por vírgula, sem espaços)
# -----------------------------------------------------------------------------
ENABLED_SOURCE_PLUGINS=github_trending,hacker_news,reddit,product_hunt
ENABLED_AI_PLUGINS=anthropic
ENABLED_NOTIFICATION_PLUGINS=telegram
ENABLED_REPORT_PLUGINS=markdown

# -----------------------------------------------------------------------------
# Credenciais de fontes de dados (opcional — preencher conforme plugins habilitados)
# -----------------------------------------------------------------------------
PRODUCT_HUNT_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=opportunity-ai-squad/0.1
GITHUB_TOKEN=
G2_API_KEY=

# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------
SCAN_INTERVAL_MINUTES=60
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_DAY=mon
MONTHLY_REPORT_DAY=1
